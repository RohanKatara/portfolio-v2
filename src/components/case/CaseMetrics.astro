---
interface Metric { label: string; value: string; }
interface Props {
  metrics: Metric[];
  accent: string;
}
const { metrics, accent } = Astro.props;
---
<div class="metrics" style={`--metric-accent: ${accent};`}>
  {metrics.map((m) => (
    <div class="metric">
      <p class="metric-value font-display">{m.value}</p>
      <p class="metric-label font-mono">{m.label}</p>
    </div>
  ))}
</div>

<style>
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin: 48px 0;
  }
  @media (max-width: 720px) {
    .metrics { grid-template-columns: repeat(2, 1fr); }
  }
  .metric {
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 4px;
    background: oklch(20% 0.012 262 / 0.5);
  }
  .metric-value {
    font-family: var(--font-display);
    font-size: 36px;
    line-height: 1;
    color: var(--metric-accent, var(--accent));
    margin: 0 0 8px;
    font-style: italic;
  }
  .metric-label {
    margin: 0;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--faint);
  }
</style>
