---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Rohan Katara">
  <main class="not-found" data-page-content>
    <div class="container">
      <p class="font-eyebrow">Error · 404</p>
      <h1 class="font-display">This page doesn't exist.</h1>
      <p class="muted">It probably never did. Let's get you back to something real.</p>
      <a href="/" class="back-link font-mono">← Return home</a>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 100dvh;
    display: flex;
    align-items: center;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 120px);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 16px 0 24px;
    color: var(--ink);
  }
  .muted {
    color: var(--muted);
    font-size: 18px;
    margin: 0 0 48px;
  }
  .back-link {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 4px;
  }
</style>
