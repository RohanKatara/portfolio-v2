---
import '../styles/global.css';
import DesktopGate from '../islands/DesktopGate.tsx';
import SmoothScroll from '../islands/SmoothScroll.tsx';
import CaseOverlayController from '../islands/CaseOverlayController.tsx';
import SpaceStarfield from '../islands/SpaceStarfield.tsx';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Rohan Katara | Software Engineer & AI Builder',
  description = 'Portfolio of Rohan Katara, a B.Tech Computer Engineering graduate based in Ahmedabad, India. Specializing in Generative AI, high-performance web environments, and immersive interactive interfaces.',
} = Astro.props;

const canonical = 'https://rohankatara.com/';

// Build-time rollback flag. Set PUBLIC_FORCE_LEGACY=1 in Vercel and redeploy
// to send every visitor to /legacy/ (the coffee portfolio) regardless of device.
const forceLegacy = import.meta.env.PUBLIC_FORCE_LEGACY === '1';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mobile + force-legacy redirect. Must run before paint, before any other
         script, and must mirror coffee-portfolio's useBreakpoint rule byte-for-byte
         (width < 768 || (hasTouch && Math.min(screen.w, screen.h) < 768)) so a
         visitor classified mobile here is also classified mobile by coffee's React
         hook on the next page. location.replace() leaves no history entry, so the
         browser back button never bounces back here. ?desktop=1 is an escape hatch
         for QA on touch laptops. -->
    <script is:inline define:vars={{ forceLegacy }}>
      (function () {
        try {
          if (location.pathname.indexOf('/legacy') === 0) return;
          if (location.search.indexOf('desktop=1') !== -1) return;
          var w = window.innerWidth;
          var hasTouch = navigator.maxTouchPoints > 0;
          var smallSide = Math.min(screen.width, screen.height);
          var isMobile = w < 768 || (hasTouch && smallSide < 768);
          if (forceLegacy || isMobile) {
            location.replace('/legacy/' + location.search + location.hash);
          }
        } catch (e) {}
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Rohan Katara" />
    <meta name="theme-color" content="#1A1B1F" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://rohankatara.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Rohan Katara Portfolio" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://rohankatara.com/og-image.png" />
    <meta name="twitter:creator" content="@Rohan2Katara" />
    <meta name="twitter:site" content="@Rohan2Katara" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      'name': 'Rohan Katara',
      'url': canonical,
      'jobTitle': 'Software Engineer & AI Builder',
      'description': description,
      'address': {
        '@type': 'PostalAddress',
        'addressLocality': 'Ahmedabad',
        'addressCountry': 'India',
      },
      'sameAs': [
        'https://github.com/RohanKatara',
        'https://www.linkedin.com/in/rohan-katara-5895952b6',
        'https://x.com/Rohan2Katara',
      ],
      'knowsAbout': [
        'React', 'Next.js', 'TypeScript', 'Generative AI',
        'Large Language Models', 'Node.js', 'Web Development',
      ],
    })} />

    <!-- Pre-paint inline guard: if the URL hash is a known case slug, lock the
         body so the homepage doesn't flash before CaseOverlayController hydrates. -->
    <script is:inline>
      (function () {
        var slugs = ['mocktalk', 'krishna', 'automate-pro', 'content-engine'];
        var h = (location.hash || '').replace(/^#/, '');
        if (slugs.indexOf(h) !== -1) {
          document.documentElement.setAttribute('data-cold-overlay', h);
        }
      })();
    </script>
    <style is:inline>
      html[data-cold-overlay] body { overflow: hidden; }
      html[data-cold-overlay] [data-page-content] { visibility: hidden; }
    </style>
  </head>
  <body>
    <DesktopGate client:only="react" />
    <SmoothScroll client:only="react" />
    <CaseOverlayController client:only="react" />
    <SpaceStarfield client:only="react" />

    <slot />
  </body>
</html>
